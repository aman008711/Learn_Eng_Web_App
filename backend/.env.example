# ==============================================================================
# Jarvis AI English Coach - Backend Environment Configuration Example
# Copy this file to .env and fill in the values. Do not check .env into version control.
# ==============================================================================

# General Application Settings
PROJECT_NAME="Jarvis AI English Coach"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-random-jwt-signing-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Supabase PostgreSQL Connection Strings
# Replace placeholders with your Supabase DB credentials
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# AI Service Credentials
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"
GEMINI_API_KEY="AIzaSy-your-google-gemini-api-key-here"

# Speech & Voice API Credentials
ELEVENLABS_API_KEY="your-elevenlabs-api-key-here"
# Default ElevenLabs Voice ID for Jarvis Coach (e.g., Rachel, Adam, or custom)
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM" 

# Supabase Object Storage Bucket for User & Response Audio
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_AUDIO_BUCKET_NAME="jarvis-coach-audio"
