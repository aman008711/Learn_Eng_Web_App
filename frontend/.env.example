# ==============================================================================
# Jarvis AI English Coach - Frontend Environment Configuration Example
# Copy this file to .env and configure the variables.
# ==============================================================================

# API Base URL (Pointing to our local/staging FastAPI instance)
VITE_API_URL="http://localhost:8000"

# Optional: Directly mapping client credentials if using direct file uploads (secure path goes through proxy)
VITE_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key-here"
